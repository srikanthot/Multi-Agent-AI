# ── Azure OpenAI (GCC High) ─────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=
 
# ── Azure AI Search (GCC High) ─────────────────────────────────
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=rag-psegtechm-index-finalv2
 
# ── Index field mappings (match your AI Search index schema) ────
# SEARCH_CONTENT_FIELD=chunk
# SEARCH_SEMANTIC_CONTENT_FIELD=chunk_for_semantic
# SEARCH_VECTOR_FIELD=text_vector
# SEARCH_FILENAME_FIELD=source_file
# SEARCH_URL_FIELD=source_url
# SEARCH_CHUNK_ID_FIELD=chunk_id
# SEARCH_TITLE_FIELD=title
# SEARCH_SECTION1_FIELD=header_1
# SEARCH_SECTION2_FIELD=header_2
# SEARCH_SECTION3_FIELD=header_3
# SEARCH_PAGE_FIELD=
 
# ── Retrieval tuning ───────────────────────────────────────────
# TOP_K=5
# RETRIEVAL_CANDIDATES=15
# VECTOR_K=50
 
# ── Retrieval quality ──────────────────────────────────────────
# USE_SEMANTIC_RERANKER=true
# SEMANTIC_CONFIG_NAME=manual-semantic-config
# MIN_RESULTS=2
# MIN_AVG_SCORE=0.02
# MIN_RERANKER_SCORE=0.3
# DIVERSITY_BY_SOURCE=true
# MAX_CHUNKS_PER_SOURCE=2
# TRACE_MODE=true
# LLM_TIMEOUT_SECONDS=120
 
# ── Azure Blob Storage (SAS tokens for PDF citation URLs) ────
# Required so the frontend can open PDF citations securely.
# Find these in Azure Portal → Storage Account → Access Keys.
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
# SAS_TOKEN_EXPIRY_MINUTES=60
 
# ── CORS ───────────────────────────────────────────────────────
# "*" for open dev, or comma-separated origins for production:
# ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.azurewebsites.net
ALLOWED_ORIGINS=*
 
# ── Azure Cosmos DB (persistent chat history) ──────────────────
# Leave COSMOS_ENDPOINT blank to run without persistence (in-memory).
COSMOS_ENDPOINT=
COSMOS_KEY=
# COSMOS_AUTH_MODE=key
# COSMOS_DATABASE=pseg-chatbot
# COSMOS_CONVERSATIONS_CONTAINER=conversations
# COSMOS_MESSAGES_CONTAINER=messages
# COSMOS_FEEDBACK_CONTAINER=feedback
# COSMOS_AUTO_CREATE_CONTAINERS=true
# COSMOS_HISTORY_MAX_TURNS=12
# COSMOS_ENABLE_TTL=false
# COSMOS_TTL_SECONDS=7776000
 
# ── Identity / debug mode ─────────────────────────────────────
# Set DEBUG_MODE=true to honor X-Debug-User-Id header from frontend.
DEBUG_MODE=true
# DEFAULT_LOCAL_USER_ID=local-user
 
# ── Entra ID JWT validation (production) ─────────────────────
# Required for per-user isolation when deployed with MSAL auth.
# ENTRA_TENANT_ID=<your-tenant-id>
# JWT_AUDIENCE=api://<backend-app-registration-client-id>
# ENTRA_CLOUD=gcc_high
 
# ── Rate limiting ────────────────────────────────────────────
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_CHAT=10/minute
# RATE_LIMIT_DEFAULT=30/minute
 
 