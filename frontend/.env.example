# Backend API URL — required for all environments
# Local dev default: http://localhost:8000
# Production: https://your-backend.azurewebsites.net
NEXT_PUBLIC_API_BASE_URL=
 
# ── Azure Entra ID Authentication ────────────────────────────────
# Leave NEXT_PUBLIC_CLIENT_ID and NEXT_PUBLIC_AUTHORITY blank for
# local debug mode (no login required, uses X-Debug-User-Id header).
#
# Set both to enable Microsoft Entra sign-in (works locally and in Azure).
# Create an App Registration in Azure Portal → Entra ID → App registrations.
NEXT_PUBLIC_CLIENT_ID=
NEXT_PUBLIC_AUTHORITY=
# Public cloud:  https://login.microsoftonline.com/<tenant-id>
# GCC High:      https://login.microsoftonline.us/<tenant-id>
 
NEXT_PUBLIC_REDIRECT_URI=/
 
# ── Backend API scope (required for JWT auth) ───────────────────
# Set this to the backend App Registration scope so MSAL acquires
# a token the backend can validate. Must match JWT_AUDIENCE on backend.
# NEXT_PUBLIC_API_SCOPE=api://<backend-client-id>/access_as_user
 
# ── Optional: Group-based access restriction ─────────────────────
# Set to an Entra security group Object ID to restrict access.
# Only members of this group will be allowed in.
# Leave blank to allow all tenant users.
# NEXT_PUBLIC_ALLOWED_GROUP=
 
 